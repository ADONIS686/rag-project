# 虚拟环境
.venv/
venv/
env/

# Python编译文件（适配所有子目录的__pycache__）
**/__pycache__/
*.pyc
*.pyog
*.pyd

# 配置文件（包含敏感信息）
config/.env
.env

# 日志文件
logs/
*.log

# 临时文件&备份
*.tmp
*.temp
temp_backup/

# 原测试数据（不提交原文，保护版权+避免仓库臃肿）
data/raw/
data/processed_documents.json

# 向量数据库（本地生成，绝不提交）
chroma_db/

# 系统垃圾文件（全平台通用）
.DS_Store
Thumbs.db